# ═══════════════════════════════════════════════════════════════════════════
# Mineway Web — Environment Variables
# คัดลอกไฟล์นี้เป็น .env แล้วกรอกค่าตามจริง
# ═══════════════════════════════════════════════════════════════════════════

# ─── Database ─────────────────────────────────────────────────────────────
DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/DATABASE"

# ─── NextAuth ─────────────────────────────────────────────────────────────
AUTH_SECRET="your-random-secret-here"
AUTH_TRUST_HOST=true
NEXTAUTH_URL="https://mineway.cloud"
APP_URL="https://mineway.cloud"

# ─── OAuth Providers ──────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Internal (Web ↔ Tunnel Server) ──────────────────────────────────────
# ต้องตรงกับค่า INTERNAL_SECRET ใน .env ของ mineway-server
INTERNAL_SECRET="change-me-to-a-long-random-string"

# ─── Dynamic Port Assignment ──────────────────────────────────────────────
PORT_RANGE_START=10000
PORT_RANGE_END=60000

# ─── Email (Resend) ──────────────────────────────────────────────────────
RESEND_API_KEY=""
EMAIL_FROM="Mineway <noreply@mineway.cloud>"
EMAIL_VERIFICATION_BYPASS="false"

# ─── Cloudflare (Optional — สำหรับ SRV record อัตโนมัติ) ─────────────────
CF_API_TOKEN=""

# ─── reCAPTCHA / Turnstile ────────────────────────────────────────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""
